              "value": "={{ [\n  { store_url: 'https://shop.polymer80.com', vendor_id: 'test_001', expected: 'small_store' },\n  { store_url: 'https://www.allbirds.com', vendor_id: 'test_002', expected: 'medium_store' },\n  { store_url: 'https://www.google.com', vendor_id: 'test_003', expected: 'not_shopify' }\n] }}",
              "type": "array"
            }
          ]
        }
      },
      "id": "setup-test-data",
      "name": "Setup Test Data",
