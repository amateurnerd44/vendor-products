# Vendor Product Data Collection System
# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# n8n Configuration
# ============================================
N8N_HOST=https://your-instance.n8n.cloud
N8N_API_KEY=your_n8n_api_key_here

# ============================================
# Zyte API Configuration (Tier 3 Scraping)
# ============================================
# Sign up at: https://www.zyte.com/zyte-api/
# Pricing: ~$0.00013 per successful request
ZYTE_API_KEY=your_zyte_api_key_here
ZYTE_API_URL=https://api.zyte.com/v1/extract

# ============================================
# Google AI Studio (Gemini API)
# ============================================
# Get API key at: https://aistudio.google.com/app/apikey
# Free tier: 60 requests/minute
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models

# ============================================
# Google Drive Integration (Tier 1)
# ============================================
# OAuth 2.0 credentials from Google Cloud Console
GOOGLE_DRIVE_CLIENT_ID=your_client_id_here
GOOGLE_DRIVE_CLIENT_SECRET=your_client_secret_here
GOOGLE_DRIVE_REDIRECT_URI=https://your-instance.n8n.cloud/oauth/callback

# ============================================
# Dropbox Integration (Tier 1)
# ============================================
# Create app at: https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your_dropbox_app_key_here
DROPBOX_APP_SECRET=your_dropbox_app_secret_here
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here

# ============================================
# Google Sheets Integration (Tier 1)
# ============================================
# Service account credentials from Google Cloud Console
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY=your_private_key_here

# ============================================
# Email Configuration (Order Triggers)
# ============================================
# For MarketTime order confirmation emails
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here

# ============================================
# Shopify Webhook Configuration (Order Triggers)
# ============================================
# Webhook URL will be: https://your-instance.n8n.cloud/webhook/shopify-orders
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here

# ============================================
# Notification Configuration
# ============================================
# For sync failure alerts and order fulfillment notifications
NOTIFICATION_EMAIL=your_notification_email@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Customer Delivery Configuration
# ============================================
# Method for delivering digital assets to customers
DELIVERY_METHOD=email
# Options: 'email', 'drive', 'dropbox', 'download_link'

# For email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Product Fulfillment System

# For Google Drive delivery (shared folder)
DELIVERY_DRIVE_FOLDER_ID=your_shared_folder_id_here

# For Dropbox delivery (shared folder)
DELIVERY_DROPBOX_FOLDER_PATH=/Shared/Customer_Orders

# ============================================
# System Configuration
# ============================================
# Weekly sync schedule (cron format)
SYNC_SCHEDULE=0 2 * * 0
# Default: Sunday at 2:00 AM

# Retry configuration
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Rate limiting
SHOPIFY_RATE_LIMIT_PER_SECOND=2
GEMINI_RATE_LIMIT_PER_MINUTE=60

# Logging level
LOG_LEVEL=info
# Options: 'debug', 'info', 'warn', 'error'

# ============================================
# Cost Monitoring
# ============================================
# Alert thresholds
MONTHLY_COST_ALERT_THRESHOLD=50
WEEKLY_COST_ALERT_THRESHOLD=15

# ============================================
# Development/Testing
# ============================================
# Set to 'true' to enable test mode (uses sample data)
TEST_MODE=false

# Test vendor IDs (comma-separated)
TEST_VENDOR_IDS=vendor_001,vendor_002,vendor_003

# ============================================
# Security
# ============================================
# Encryption key for sensitive data in n8n tables
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_32_character_encryption_key_here

# API request timeout (seconds)
API_TIMEOUT=30

# ============================================
# Notes
# ============================================
# 1. Never commit the actual .env file to version control
# 2. Store production credentials in n8n's credential manager
# 3. Use n8n environment variables for sensitive values
# 4. Rotate API keys quarterly for security
# 5. Monitor API usage to stay within budget (~$222/year target)

